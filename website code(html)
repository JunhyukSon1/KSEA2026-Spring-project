  ];

  // ================== RENDER BOARDS ==================
  function renderBoards(filter='all'){
    const grid = document.getElementById('boardGrid');
    grid.innerHTML = BOARDS.map((b,i)=>{
      const hidden = (filter!=='all' && b.tag!==filter) ? 'hidden':'';
      return `
        <div class="board-card ${b.color} ${hidden}" onclick="openBoard('${b.id}')" style="animation-delay:${i*40}ms">
          <div class="b-arrow">↗</div>
          <span class="b-emoji">${b.emoji}</span>
          <h3>${b.name}</h3>
          <p>${b.desc}</p>
          <div class="b-foot">
            <span class="b-count"><span class="pulse"></span>${b.count} 실시간</span>
            <span>열기 →</span>
          </div>
        </div>
      `;
    }).join('');
  }
  renderBoards();

  // Filter chips
  document.querySelectorAll('#filterChips .chip').forEach(chip=>{
    chip.addEventListener('click',()=>{
      document.querySelectorAll('#filterChips .chip').forEach(c=>c.classList.remove('active'));
      chip.classList.add('active');
      const f = chip.dataset.filter;
      // re-render with filter (animated)
      const cards = document.querySelectorAll('.board-card');
      cards.forEach(card=>{
        card.style.opacity='0';
        card.style.transform='translateY(10px)';
      });
      setTimeout(()=>{
        renderBoards(f);
        document.querySelectorAll('.board-card').forEach((card,i)=>{
          card.style.opacity='0';
          card.style.transform='translateY(10px)';
          setTimeout(()=>{
            card.style.transition='opacity .35s, transform .35s';
            card.style.opacity='1';
            card.style.transform='';
          }, i*30);
        });
      },180);
    });
  });

  // ================== MODAL ==================
  const modalBg = document.getElementById('modalBg');
  function openBoard(id){
    const b = BOARDS.find(x=>x.id===id);
    if(!b) return;
    document.getElementById('mEmoji').textContent = b.emoji;
    document.getElementById('mTitle').textContent = b.name;
    document.getElementById('mDesc').textContent = b.desc;
    document.getElementById('mPosts').innerHTML = b.posts.map((p,i)=>`
      <div class="preview-post"><strong>${p}</strong><small>${Math.floor(Math.random()*59)+1}분 전</small></div>
    `).join('');
    modalBg.classList.add('open');
    document.body.style.overflow='hidden';
  }
  function closeModal(e){
    if(e && e.target.closest('.modal')) return;
    modalBg.classList.remove('open');
    document.body.style.overflow='';
  }
  document.addEventListener('keydown',e=>{if(e.key==='Escape') closeModal()});

  // ================== TOAST ==================
  let toastTimer;
  function toast(msg){
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.classList.add('show');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(()=>t.classList.remove('show'),1800);
  }

  // ================== LIVE TICKER ==================
  const feed = document.getElementById('tickerFeed');
  TICKER_ITEMS.forEach((it,i)=>{
    const div = document.createElement('div');
    div.className='ticker-item'+(i===0?' current':'');
    div.innerHTML=`<span class="tag-pill">${it.tag}</span>${it.text}`;
    feed.appendChild(div);
  });
  let tIdx = 0;
  setInterval(()=>{
    const items = feed.querySelectorAll('.ticker-item');
    items[tIdx].classList.remove('current');
    items[tIdx].classList.add('out');
    setTimeout(()=>items[tIdx].classList.remove('out'), 500);
    tIdx = (tIdx+1) % items.length;
    items[tIdx].classList.add('current');
  },3000);

  // ================== REVEAL ON SCROLL ==================
  const io = new IntersectionObserver((entries)=>{
    entries.forEach((e,i)=>{
      if(e.isIntersecting){
        setTimeout(()=>e.target.classList.add('in'), i*60);
        io.unobserve(e.target);
      }
    });
  },{threshold:.12});
  document.querySelectorAll('.reveal').forEach(el=>io.observe(el));

  // ================== COUNTER ANIMATION ==================
  function animateCount(el){
    const target = parseFloat(el.dataset.count);
    const decimals = parseInt(el.dataset.decimals || '0');
    const suffix = el.dataset.suffix || '';
    const duration = 1800;
    const start = performance.now();
    function tick(now){
      const p = Math.min(1, (now-start)/duration);
      const eased = 1 - Math.pow(1-p, 3);
      const val = target * eased;
      let display;
      if(target >= 1000000) display = (val/1000000).toFixed(decimals||1).replace(/\.0$/,'')+'M';
      else if(target >= 10000) display = Math.floor(val/10000)+'만';
      else if(decimals>0) display = val.toFixed(decimals);
      else display = Math.floor(val);
      el.textContent = display + suffix;
      if(p<1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }
  const statsIO = new IntersectionObserver((entries)=>{
    entries.forEach(e=>{
      if(e.isIntersecting){
        e.target.querySelectorAll('[data-count]').forEach(el=>animateCount(el));
        statsIO.unobserve(e.target);
      }
    });
  },{threshold:.3});
  statsIO.observe(document.getElementById('stats'));

