<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>캠퍼즈 Campuzz — 우리 학교 모든 게 다 있어 🎓</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Black+Han+Sans&family=Jua&family=Gaegu:wght@400;700&family=Noto+Sans+KR:wght@400;500;700;900&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
  :root{
    --ink:#0f0f0f;
    --cream:#fff8e7;
    --hot:#ff3ea5;
    --lime:#c6ff3d;
    --sky:#3ec1ff;
    --sun:#ffd23f;
    --violet:#a06cff;
    --coral:#ff6b3d;
    --mint:#6df2a8;
    --peach:#ffb3a7;
    --paper:#fffaf0;
    --muted:#6b6b6b;
  }
  [data-theme="dark"]{
    --ink:#fff8e7;
    --cream:#161616;
    --paper:#1d1d1d;
    --muted:#999;
  }
  *{box-sizing:border-box;margin:0;padding:0}
  html{scroll-behavior:smooth}
  html,body{background:var(--cream);color:var(--ink);font-family:'Noto Sans KR',sans-serif;overflow-x:hidden;transition:background .3s,color .3s}
  body{
    background-image:
      radial-gradient(circle at 10% 10%, rgba(255,62,165,.08), transparent 30%),
      radial-gradient(circle at 90% 30%, rgba(62,193,255,.1), transparent 35%),
      radial-gradient(circle at 30% 80%, rgba(198,255,61,.12), transparent 30%);
  }
  body::before{
    content:"";position:fixed;inset:0;pointer-events:none;z-index:1;opacity:.35;mix-blend-mode:multiply;
    background-image:url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='200' height='200'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2' stitchTiles='stitch'/></filter><rect width='100%25' height='100%25' filter='url(%23n)' opacity='0.22'/></svg>");
  }
  [data-theme="dark"] body::before{opacity:.15}

  a{color:inherit;text-decoration:none}
  button{font-family:inherit;cursor:pointer;border:none;background:none;color:inherit}
  .container{max-width:1200px;margin:0 auto;padding:0 24px;position:relative;z-index:2}

  /* ===== NAV ===== */
  nav{
    position:sticky;top:0;z-index:50;
    background:var(--cream);
    border-bottom:3px solid var(--ink);
    transition:background .3s;
  }
  .nav-inner{display:flex;align-items:center;justify-content:space-between;padding:14px 24px;max-width:1200px;margin:0 auto;gap:12px}
  .logo{font-family:'Black Han Sans',sans-serif;font-size:30px;letter-spacing:-1px;display:flex;align-items:center;gap:8px;cursor:pointer}
  .logo .dot{display:inline-block;width:14px;height:14px;background:var(--hot);border:2px solid var(--ink);border-radius:50%;transform:translateY(-3px)}
  .nav-links{display:flex;gap:24px;font-weight:700;font-size:15px}
  .nav-links a{position:relative;padding:4px 0;cursor:pointer}
  .nav-links a:hover{color:var(--hot)}
  .nav-right{display:flex;gap:10px;align-items:center}
  .theme-toggle{
    width:40px;height:40px;border-radius:50%;border:2px solid var(--ink);
    background:var(--paper);display:grid;place-items:center;font-size:16px;
    box-shadow:3px 3px 0 var(--ink);transition:transform .15s;
  }
  .theme-toggle:hover{transform:rotate(20deg)}
  .nav-cta{
    font-family:'Jua',sans-serif;font-size:15px;
    background:var(--ink);color:var(--cream);
    padding:10px 20px;border-radius:999px;border:2px solid var(--ink);
    box-shadow:4px 4px 0 var(--lime);
    transition:transform .15s, box-shadow .15s;
  }
  .nav-cta:hover{transform:translate(-2px,-2px);box-shadow:6px 6px 0 var(--lime)}
  @media (max-width:760px){.nav-links{display:none}}

  /* ===== LIVE TICKER ===== */
  .ticker{
    background:var(--ink);color:var(--cream);border-bottom:3px solid var(--ink);
    padding:10px 0;overflow:hidden;position:relative;display:flex;align-items:center;gap:16px;
  }
  .ticker-label{
    flex:0 0 auto;padding:0 16px;font-family:'Black Han Sans',sans-serif;font-size:14px;
    display:flex;align-items:center;gap:8px;color:var(--hot);
  }
  .ticker-label .dot{width:8px;height:8px;background:var(--hot);border-radius:50%;animation:blink 1s infinite}
  @keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}
  .ticker-feed{flex:1;overflow:hidden;position:relative;height:20px}
  .ticker-item{
    position:absolute;width:100%;font-size:14px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
    transform:translateY(20px);transition:transform .5s cubic-bezier(.4,0,.2,1), opacity .4s;opacity:0;
  }
  .ticker-item.current{transform:translateY(0);opacity:1}
  .ticker-item.out{transform:translateY(-20px);opacity:0}
  .ticker-item .tag-pill{background:var(--lime);color:var(--ink);padding:2px 8px;border-radius:999px;font-weight:700;font-size:11px;margin-right:8px}

  /* ===== HERO ===== */
  .hero{position:relative;padding:60px 0 100px}
  .eyebrow{
    display:inline-block;font-family:'Space Mono',monospace;font-weight:700;font-size:13px;
    background:var(--sun);border:2px solid var(--ink);padding:6px 14px;border-radius:999px;
    transform:rotate(-2deg);box-shadow:3px 3px 0 var(--ink);margin-bottom:24px;color:#0f0f0f;
  }
  h1.hero-title{
    font-family:'Black Han Sans',sans-serif;
    font-size:clamp(48px,8vw,112px);line-height:.95;letter-spacing:-2px;max-width:900px;
  }
  h1.hero-title .wave{display:inline-block;color:var(--hot)}
  h1.hero-title .underline{background:linear-gradient(transparent 65%, var(--lime) 65%);padding:0 6px;color:var(--ink)}
  h1.hero-title .circle{display:inline-block;position:relative}
  h1.hero-title .circle::after{content:"";position:absolute;inset:-8px -12px;border:4px solid var(--hot);border-radius:50%;transform:rotate(-6deg)}
  .hero-sub{margin-top:28px;max-width:560px;font-size:19px;line-height:1.6;font-weight:500;color:var(--muted)}
  .hero-cta{display:flex;gap:14px;margin-top:36px;flex-wrap:wrap}
  .btn{
    font-family:'Jua',sans-serif;font-size:18px;padding:16px 28px;border-radius:999px;border:2.5px solid var(--ink);
    cursor:pointer;transition:transform .15s, box-shadow .15s;display:inline-flex;align-items:center;gap:10px;
  }
  .btn.primary{background:var(--hot);color:var(--cream);box-shadow:6px 6px 0 var(--ink)}
  .btn.primary:hover{transform:translate(-3px,-3px);box-shadow:9px 9px 0 var(--ink)}
  .btn.ghost{background:var(--cream);color:var(--ink);box-shadow:6px 6px 0 var(--sky)}
  .btn.ghost:hover{transform:translate(-3px,-3px);box-shadow:9px 9px 0 var(--sky)}

  .hero-meta{display:flex;gap:28px;margin-top:44px;flex-wrap:wrap;align-items:center}
  .avatars{display:flex}
  .avatars span{width:40px;height:40px;border-radius:50%;border:3px solid var(--cream);display:inline-block;margin-left:-10px;font-size:22px;text-align:center;line-height:36px;transition:transform .2s;cursor:pointer}
  .avatars span:hover{transform:translateY(-4px) scale(1.1);z-index:2}
  .avatars span:nth-child(1){background:var(--hot);margin-left:0}
  .avatars span:nth-child(2){background:var(--lime)}
  .avatars span:nth-child(3){background:var(--sky)}
  .avatars span:nth-child(4){background:var(--sun)}
  .avatars span:nth-child(5){background:var(--violet)}
  .hero-meta small{font-weight:700;font-size:13px;color:var(--muted)}
  .hero-meta strong{color:var(--ink);font-size:15px;display:block}

  .sticker{
    position:absolute;font-family:'Jua',sans-serif;background:var(--paper);
    border:2.5px solid var(--ink);border-radius:16px;padding:10px 14px;font-size:15px;
    box-shadow:4px 4px 0 var(--ink);z-index:3;color:#0f0f0f;
  }
  .sticker.s1{top:80px;right:8%;background:var(--lime);--r:6deg;animation:float 4s ease-in-out infinite}
  .sticker.s2{top:240px;right:22%;background:var(--sky);--r:-5deg;animation:float 5s ease-in-out infinite .5s}
  .sticker.s3{bottom:120px;right:5%;background:var(--sun);--r:4deg;animation:float 4.5s ease-in-out infinite 1s}
  .sticker.s4{bottom:60px;left:3%;background:var(--coral);--r:-8deg;color:var(--cream);animation:float 5.5s ease-in-out infinite .3s}
  @keyframes float{0%,100%{transform:translateY(0) rotate(var(--r,0deg))}50%{transform:translateY(-12px) rotate(var(--r,0deg))}}

  .hero-grid{display:grid;grid-template-columns:1.2fr .8fr;gap:40px;align-items:center}
  @media (max-width:900px){.hero-grid{grid-template-columns:1fr}.sticker{display:none}}

  .phone-wrap{position:relative;display:flex;justify-content:center;align-items:center;min-height:560px}
  .phone{width:280px;height:560px;background:#0f0f0f;border-radius:44px;padding:10px;box-shadow:12px 12px 0 var(--hot),24px 24px 0 var(--lime);position:relative}
  .phone-screen{width:100%;height:100%;background:var(--paper);border-radius:34px;overflow:hidden;position:relative}
  .notch{position:absolute;top:10px;left:50%;transform:translateX(-50%);width:100px;height:22px;background:#0f0f0f;border-radius:999px;z-index:5}
  .app-header{background:var(--hot);color:var(--cream);padding:44px 18px 18px;font-family:'Black Han Sans',sans-serif;font-size:22px;display:flex;justify-content:space-between;align-items:flex-end}
  .app-header .bell{background:var(--cream);color:#0f0f0f;width:32px;height:32px;border-radius:50%;border:2px solid #0f0f0f;display:grid;place-items:center;font-size:16px}
  .app-tabs{display:flex;gap:6px;padding:12px;background:var(--paper);overflow-x:auto;scrollbar-width:none}
  .app-tabs::-webkit-scrollbar{display:none}
  .tab{flex:0 0 auto;padding:6px 12px;border:2px solid #0f0f0f;border-radius:999px;font-size:12px;font-weight:700;background:var(--paper);color:#0f0f0f}
  .tab.active{background:var(--sun)}
  .feed{padding:10px 14px;display:flex;flex-direction:column;gap:10px}
  .feed-post{background:#fffaf0;border:2px solid #0f0f0f;border-radius:14px;padding:12px;box-shadow:3px 3px 0 #0f0f0f;color:#0f0f0f}
  .feed-post .who{display:flex;justify-content:space-between;font-size:11px;color:#666;margin-bottom:6px;font-weight:700}
  .feed-post h4{font-family:'Jua',sans-serif;font-size:15px;margin-bottom:4px}
  .feed-post p{font-size:12px;color:#444;line-height:1.4}
  .feed-post .meta{display:flex;gap:10px;margin-top:8px;font-size:11px;color:#777;font-weight:700}

  /* ===== MARQUEE ===== */
  .marquee{background:var(--ink);color:var(--cream);border-top:3px solid var(--ink);border-bottom:3px solid var(--ink);overflow:hidden;padding:18px 0}
  .marquee-track{display:flex;gap:48px;white-space:nowrap;animation:scroll 28s linear infinite;font-family:'Black Han Sans',sans-serif;font-size:36px;letter-spacing:-1px}
  .marquee-track span{display:inline-flex;align-items:center;gap:48px}
  @keyframes scroll{from{transform:translateX(0)}to{transform:translateX(-50%)}}
  .marquee:hover .marquee-track{animation-play-state:paused}

  /* ===== SECTION COMMON ===== */
  .section-eyebrow{font-family:'Space Mono',monospace;font-weight:700;font-size:13px;letter-spacing:2px;color:var(--hot);text-transform:uppercase;margin-bottom:16px}
  .section-title{font-family:'Black Han Sans',sans-serif;font-size:clamp(40px,6vw,80px);line-height:1;letter-spacing:-1.5px;max-width:800px;margin-bottom:20px}
  .section-desc{font-size:18px;color:var(--muted);max-width:600px;margin-bottom:56px;line-height:1.6;font-weight:500}

  /* ===== AD SLOTS ===== */
  .ad-slot{
    position:relative;background:var(--paper);border:2.5px dashed var(--ink);border-radius:20px;
    padding:32px 24px;text-align:center;margin:40px 0;overflow:hidden;
    transition:transform .2s;
  }
  .ad-slot::before{
    content:"AD · 광고 자리";position:absolute;top:12px;left:12px;
    font-family:'Space Mono',monospace;font-size:10px;font-weight:700;
    background:var(--ink);color:var(--cream);padding:3px 8px;border-radius:4px;letter-spacing:1px;
  }
  .ad-slot.billboard{min-height:180px;background:linear-gradient(135deg,var(--sun),var(--peach))}
  .ad-slot.billboard .ad-content{display:flex;align-items:center;justify-content:center;gap:20px;flex-wrap:wrap}
  .ad-slot.billboard .ad-visual{font-size:72px}
  .ad-slot.billboard h4{font-family:'Black Han Sans',sans-serif;font-size:32px;letter-spacing:-1px;color:#0f0f0f;line-height:1}
  .ad-slot.billboard p{color:#0f0f0f;font-weight:500;margin-top:6px}
  .ad-slot.inline{background:linear-gradient(135deg,var(--sky),var(--mint));padding:20px}
  .ad-slot.inline .ad-content{display:flex;align-items:center;gap:16px;justify-content:center;flex-wrap:wrap}
  .ad-slot.inline h4{font-family:'Jua',sans-serif;font-size:20px;color:#0f0f0f}
  .ad-slot.inline p{color:#0f0f0f;font-size:14px;font-weight:500}
  .ad-slot.inline .cta{background:#0f0f0f;color:var(--cream);padding:10px 18px;border-radius:999px;font-weight:700;font-size:14px;border:2px solid #0f0f0f}
  .ad-slot.inline .cta:hover{background:var(--cream);color:#0f0f0f}
  .ad-slot.small{min-height:100px;padding:20px;display:flex;align-items:center;justify-content:center;gap:14px}
  .ad-slot.small h4{font-family:'Jua',sans-serif;font-size:16px;color:#0f0f0f}
  .ad-swap{font-family:'Space Mono',monospace;font-size:10px;color:var(--muted);margin-top:8px}

  /* ===== BOARDS SECTION ===== */
  .boards{padding:100px 0 60px;position:relative}
  .boards-controls{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:40px;flex-wrap:wrap;gap:20px}
  .boards-controls .left{flex:1;min-width:260px}
  .filter-chips{display:flex;gap:8px;flex-wrap:wrap}
  .chip{
    font-family:'Jua',sans-serif;font-size:13px;padding:8px 14px;border-radius:999px;
    border:2px solid var(--ink);background:var(--paper);color:var(--ink);
    box-shadow:2px 2px 0 var(--ink);transition:transform .1s;
  }
  .chip:hover{transform:translate(-1px,-1px);box-shadow:3px 3px 0 var(--ink)}
  .chip.active{background:var(--ink);color:var(--cream);box-shadow:2px 2px 0 var(--hot)}

  .board-grid{
    display:grid;grid-template-columns:repeat(4,1fr);gap:18px;
  }
  @media (max-width:900px){.board-grid{grid-template-columns:repeat(2,1fr)}}
  @media (max-width:500px){.board-grid{grid-template-columns:1fr}}

  .board-card{
    position:relative;background:var(--paper);border:2.5px solid var(--ink);
    border-radius:20px;padding:22px 20px;box-shadow:5px 5px 0 var(--ink);
    cursor:pointer;transition:transform .2s, box-shadow .2s;
    overflow:hidden;
  }
  .board-card:hover{transform:translate(-4px,-4px);box-shadow:9px 9px 0 var(--ink)}
  .board-card:hover .b-arrow{transform:translate(4px,-4px) rotate(-45deg)}
  .board-card .b-emoji{font-size:38px;margin-bottom:10px;display:block;transition:transform .3s}
  .board-card:hover .b-emoji{transform:scale(1.15) rotate(-8deg)}
  .board-card h3{font-family:'Black Han Sans',sans-serif;font-size:22px;letter-spacing:-.5px;margin-bottom:6px}
  .board-card p{font-size:13px;color:var(--muted);line-height:1.45;font-weight:500;margin-bottom:14px;min-height:38px}
  .board-card .b-foot{display:flex;justify-content:space-between;align-items:center;font-family:'Space Mono',monospace;font-size:11px;font-weight:700;color:var(--muted)}
  .board-card .b-count{display:inline-flex;align-items:center;gap:5px}
  .board-card .b-count .pulse{width:6px;height:6px;background:var(--hot);border-radius:50%;animation:blink 1.5s infinite}
  .board-card .b-arrow{
    position:absolute;top:18px;right:18px;width:32px;height:32px;
    background:var(--ink);color:var(--cream);border-radius:50%;
    display:grid;place-items:center;font-size:14px;font-weight:900;
    transition:transform .2s;
  }
  /* card color variants */
  .bc-1{background:var(--hot);color:var(--cream)}
  .bc-1 p,.bc-1 .b-foot{color:rgba(255,248,231,.85)}
  .bc-1 .b-arrow{background:var(--cream);color:var(--hot)}
  .bc-2{background:var(--lime)}
  .bc-3{background:var(--sky)}
  .bc-4{background:var(--sun)}
  .bc-5{background:var(--violet);color:var(--cream)}
  .bc-5 p,.bc-5 .b-foot{color:rgba(255,248,231,.85)}
  .bc-5 .b-arrow{background:var(--cream);color:var(--violet)}
  .bc-6{background:var(--coral);color:var(--cream)}
  .bc-6 p,.bc-6 .b-foot{color:rgba(255,248,231,.85)}
  .bc-6 .b-arrow{background:var(--cream);color:var(--coral)}
  .bc-7{background:var(--mint)}
  .bc-8{background:var(--peach)}

  .board-card.hidden{display:none}

  /* ===== FEATURES SHORT ===== */
  .features{padding:80px 0;position:relative}
  .feat-row{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
  @media (max-width:800px){.feat-row{grid-template-columns:1fr}}
  .feat-card{
    background:var(--paper);border:3px solid var(--ink);border-radius:24px;
    padding:28px;box-shadow:6px 6px 0 var(--ink);transition:transform .2s,box-shadow .2s;
  }
  .feat-card:hover{transform:translate(-4px,-4px);box-shadow:10px 10px 0 var(--ink)}
  .feat-card .icon{width:58px;height:58px;border-radius:18px;border:2.5px solid var(--ink);display:grid;place-items:center;font-size:28px;margin-bottom:18px;box-shadow:3px 3px 0 var(--ink);background:var(--hot);color:var(--cream)}
  .feat-card:nth-child(2) .icon{background:var(--lime);color:#0f0f0f}
  .feat-card:nth-child(3) .icon{background:var(--sky);color:#0f0f0f}
  .feat-card h3{font-family:'Jua',sans-serif;font-size:22px;margin-bottom:10px;letter-spacing:-.5px}
  .feat-card p{color:var(--muted);line-height:1.6;font-size:15px;font-weight:500}

  /* ===== STATS ===== */
  .stats{padding:80px 0;background:var(--ink);color:var(--cream);border-top:3px solid var(--ink);border-bottom:3px solid var(--ink);position:relative}
  .stats [data-theme-ignore]{}
  .stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:40px;text-align:center}
  @media (max-width:800px){.stats-grid{grid-template-columns:repeat(2,1fr)}}
  .stat .num{font-family:'Black Han Sans',sans-serif;font-size:clamp(48px,7vw,88px);line-height:1;letter-spacing:-2px;color:var(--lime)}
  .stat:nth-child(2) .num{color:var(--hot)}
  .stat:nth-child(3) .num{color:var(--sky)}
  .stat:nth-child(4) .num{color:var(--sun)}
  .stat .label{font-family:'Jua',sans-serif;font-size:16px;margin-top:8px;color:rgba(255,248,231,.85)}

  /* ===== TESTIMONIALS ===== */
  .testimonials{padding:100px 0 60px;position:relative}
  .bubbles{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
  @media (max-width:900px){.bubbles{grid-template-columns:1fr}}
  .bubble{background:var(--paper);border:3px solid var(--ink);border-radius:24px;padding:24px;position:relative;box-shadow:6px 6px 0 var(--ink);color:#0f0f0f}
  .bubble::before{content:"";position:absolute;bottom:-18px;left:36px;width:22px;height:22px;background:var(--paper);border-right:3px solid var(--ink);border-bottom:3px solid var(--ink);transform:rotate(45deg)}
  .bubble.b1{transform:rotate(-1deg);background:var(--lime)}
  .bubble.b1::before{background:var(--lime)}
  .bubble.b2{transform:rotate(1deg);background:var(--sky);margin-top:30px}
  .bubble.b2::before{background:var(--sky)}
  .bubble.b3{transform:rotate(-.5deg);background:var(--sun)}
  .bubble.b3::before{background:var(--sun)}
  .bubble p{font-size:17px;line-height:1.5;font-weight:500;margin-bottom:16px;font-family:'Gaegu',cursive}
  .bubble .who{display:flex;align-items:center;gap:12px;margin-top:30px}
  .bubble .who .ava{width:44px;height:44px;border-radius:50%;border:2.5px solid #0f0f0f;display:grid;place-items:center;font-size:22px;background:#fff8e7}
  .bubble .who strong{font-family:'Jua',sans-serif;font-size:16px;display:block}
  .bubble .who small{font-size:13px;color:#444;font-weight:700}

  /* ===== CTA ===== */
  .cta{padding:100px 0;text-align:center;position:relative}
  .cta-box{background:var(--hot);color:var(--cream);border:4px solid var(--ink);border-radius:40px;padding:80px 40px;box-shadow:12px 12px 0 var(--ink);position:relative;overflow:hidden}
  .cta-box::before{content:"";position:absolute;inset:0;opacity:.35;pointer-events:none;background-image:radial-gradient(circle at 20% 20%, var(--sun) 0, transparent 14%),radial-gradient(circle at 80% 30%, var(--lime) 0, transparent 16%),radial-gradient(circle at 30% 80%, var(--sky) 0, transparent 14%),radial-gradient(circle at 85% 75%, var(--violet) 0, transparent 14%)}
